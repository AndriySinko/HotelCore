{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "HotelCore": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=hotelcore;Username=hotelcore;Password=REPLACE_IN_ENV"
  },
  "JwtSettings": {
    "Secret": "REPLACE_IN_ENV",
    "Issuer": "HotelCore.Api",
    "Audience": "HotelCore.Client",
    "ExpiryMinutes": 480,
    "RefreshTokenExpiryDays": 7
  }
}
